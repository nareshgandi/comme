#!/usr/bin/env python3

import csv
import json
import random
from datetime import date, timedelta

EMPLOYEE_FILE = "employees.csv"
LOCATION_FILE = "location.csv"

# Increase until employees.csv reaches ~300MB
NUM_EMPLOYEES = 1_800_000

NUM_LOCATIONS = 15000

first_names = [
    "John","Jane","Michael","David","Sarah","Robert","Emily","Daniel",
    "Priya","Rahul","Anita","Kishore","Naresh","Suresh","Amit","Ravi",
    "Sneha","Pooja","Arjun","Meera","Krishna","Sanjay","Vijay"
]

last_names = [
    "Smith","Johnson","Brown","Taylor","Wilson","Thomas",
    "Sharma","Reddy","Patel","Gupta","Kumar","Verma",
    "Singh","Rao","Iyer","Nair","Das"
]

cities = [
    "Hyderabad","Bengaluru","Chennai","Mumbai","Delhi",
    "Pune","Kolkata","Ahmedabad","Jaipur","Lucknow"
]

departments = list(range(1, 51))

skills_pool = [
    "PostgreSQL","Oracle","MySQL","MongoDB","AWS",
    "Linux","Python","Java","Docker","Kubernetes",
    "Redis","Kafka","Terraform","Ansible","Shell",
    "Azure","GCP","Patroni","PgBouncer","Performance"
]

statuses = ["ACTIVE"] * 80 + ["INACTIVE"] * 20

descriptions = [
    "Experienced database administrator with strong PostgreSQL background.",
    "Cloud engineer responsible for production infrastructure.",
    "Software engineer working on backend services.",
    "Database reliability engineer maintaining HA clusters.",
    "DevOps engineer with automation expertise.",
    "Senior DBA handling performance tuning and migrations."
]

start_date = date(2010, 1, 1)

print("Generating employees.csv...")

with open(EMPLOYEE_FILE, "w", newline="", encoding="utf-8") as f:
    writer = csv.writer(f)

    for i in range(NUM_EMPLOYEES):

        fn = random.choice(first_names)
        ln = random.choice(last_names)

        full_name = f"{fn} {ln}"

        email = f"{fn.lower()}.{ln.lower()}{i}@company.com"

        dept = random.choice(departments)

        salary = round(random.uniform(30000, 250000), 2)

        hire = start_date + timedelta(days=random.randint(0, 5500))

        skills = random.sample(skills_pool, random.randint(2, 5))

        city = random.choice(cities)

        profile = {
            "city": city,
            "status": random.choice(statuses),
            "experience": random.randint(1, 20),
            "certified": random.choice([True, False])
        }

        x = round(random.uniform(0, 100), 3)
        y = round(random.uniform(0, 100), 3)

        point = f"({x},{y})"

        desc = random.choice(descriptions)

        writer.writerow([
            full_name,
            email,
            dept,
            salary,
            hire.isoformat(),
            "{" + ",".join(skills) + "}",
            json.dumps(profile),
            point,
            desc
        ])

        if i % 100000 == 0 and i > 0:
            print(f"{i:,} rows")

print("Generating location.csv...")

with open(LOCATION_FILE, "w", newline="", encoding="utf-8") as f:

    writer = csv.writer(f)

    for i in range(NUM_LOCATIONS):

        city = random.choice(cities)

        x = random.randint(0, 100)

        y = random.randint(0, 100)

        polygon = (
            f"(({x},{y}),"
            f"({x+5},{y}),"
            f"({x+5},{y+5}),"
            f"({x},{y+5}))"
        )

        created = start_date + timedelta(days=random.randint(0, 5500))

        writer.writerow([
            city,
            polygon,
            created.isoformat()
        ])

print("Done.")
